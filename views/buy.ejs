<%- include("partials/header") %>

<div class="site-shell">
  <header class="simple-nav container">
    <a class="brand-mark" href="/">myurlc.com</a>
    <a class="text-link" href="/">Back home</a>
  </header>

  <main class="container narrow">
    <section class="card">
      <p class="eyebrow">Step 1 of 2</p>
      <h1>Kick off a custom bio page</h1>
      <p class="lead">
        Use Stripe to take a fast setup payment, or keep the workflow manual while you test the service.
      </p>

      <div class="offer-banner">
        <span>Starter hook</span>
        <strong><%= offerPriceDisplay %> deposit for a branded bio page</strong>
      </div>

      <div class="feature-list">
        <div class="feature-item">Custom page URL like <code>/mariahair</code></div>
        <div class="feature-item">Theme + accent color selection</div>
        <div class="feature-item">Profile photo or logo upload</div>
        <div class="feature-item">Up to 8 call-to-action links</div>
      </div>

      <p class="field-hint">Want the self-serve version instead? <a class="text-link" href="/signup">Create an account</a>.</p>

      <% if (stripeEnabled) { %>
        <form method="POST" action="/create-checkout-session">
          <button class="btn" type="submit">Pay <%= offerPriceDisplay %> and continue</button>
        </form>
      <% } else { %>
        <div class="notice">
          Stripe is not configured yet. You can still submit manual/test orders using the intake form.
        </div>
        <a class="btn" href="/intake">Continue without Stripe</a>
      <% } %>
    </section>
  </main>
</div>

<%- include("partials/footer") %>
