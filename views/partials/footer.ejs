<a class="support-fab" data-support-launch href="/support" aria-label="Help or report bugs" title="Help or report bugs">
  <span class="icon-svg"><%- iconSvg("help") %></span>
  <span class="support-fab-label">Help</span>
</a>

<script>
  if (document.querySelector(".profile-page-public .profile-mobile-dock")) {
    document.body.classList.add("has-profile-mobile-dock");
  }

  if (document.querySelector(".studio-actions")) {
    document.body.classList.add("has-studio-action-dock");
  }

  document.querySelectorAll("[data-support-launch]").forEach((link) => {
    const currentPath = `${window.location.pathname}${window.location.search}`;
    link.setAttribute("href", `/support?from=${encodeURIComponent(currentPath)}`);
  });

  document.querySelectorAll("[data-link-builder]").forEach((builder) => {
    const revealButton = builder.querySelector("[data-reveal-links]");
    const rows = Array.from(builder.querySelectorAll("[data-link-row]"));
    const tools = builder.querySelector(".link-builder-tools");
    let draggedRow = null;

    const syncRevealButton = () => {
      if (!revealButton) {
        return;
      }

      const hiddenRows = rows.filter((row) => row.classList.contains("is-hidden-empty"));
      revealButton.hidden = hiddenRows.length === 0;
    };

    revealButton?.addEventListener("click", () => {
      rows
        .filter((row) => row.classList.contains("is-hidden-empty"))
        .slice(0, 4)
        .forEach((row) => row.classList.remove("is-hidden-empty"));

      syncRevealButton();
      syncDragState();
    });

    const getVisibleRows = () => rows.filter((row) => !row.classList.contains("is-hidden-empty"));

    const syncDragState = () => {
      rows.forEach((row) => {
        const handle = row.querySelector("[data-link-drag-handle]");
        const canDrag = !row.classList.contains("is-hidden-empty");
        row.removeAttribute("draggable");
        row.classList.remove("is-dragging");

        if (handle) {
          handle.hidden = !canDrag;
          handle.disabled = !canDrag;
        }
      });
    };

    const getDragAfterElement = (clientY) => {
      return getVisibleRows()
        .filter((row) => row !== draggedRow)
        .reduce((closest, row) => {
          const box = row.getBoundingClientRect();
          const offset = clientY - box.top - (box.height / 2);

          if (offset < 0 && offset > closest.offset) {
            return { offset, element: row };
          }

          return closest;
        }, { offset: Number.NEGATIVE_INFINITY, element: null }).element;
    };

    rows.forEach((row) => {
      const handle = row.querySelector("[data-link-drag-handle]");
      const enableDragging = () => {
        if (!row.classList.contains("is-hidden-empty")) {
          row.setAttribute("draggable", "true");
        }
      };
      const disableDragging = () => {
        row.removeAttribute("draggable");
      };

      handle?.addEventListener("mousedown", enableDragging);
      handle?.addEventListener("touchstart", enableDragging, { passive: true });
      handle?.addEventListener("mouseup", disableDragging);
      handle?.addEventListener("mouseleave", disableDragging);
      handle?.addEventListener("touchend", disableDragging);

      row.addEventListener("dragstart", (event) => {
        if (row.classList.contains("is-hidden-empty")) {
          event.preventDefault();
          return;
        }

        draggedRow = row;
        row.classList.add("is-dragging");
        if (event.dataTransfer) {
          event.dataTransfer.effectAllowed = "move";
          event.dataTransfer.setData("text/plain", row.querySelector("input[name='link_label']")?.value || "link");
        }
      });

      row.addEventListener("dragend", () => {
        disableDragging();
        row.classList.remove("is-dragging");
        draggedRow = null;
      });
    });

    builder.addEventListener("dragover", (event) => {
      if (!draggedRow) {
        return;
      }

      event.preventDefault();
      const afterElement = getDragAfterElement(event.clientY);
      if (afterElement) {
        builder.insertBefore(draggedRow, afterElement);
      } else if (tools) {
        builder.insertBefore(draggedRow, tools);
      } else {
        builder.appendChild(draggedRow);
      }
    });

    syncRevealButton();
    syncDragState();
  });

  document.querySelectorAll("[data-share-page]").forEach((button) => {
    const defaultLabel = button.querySelector("[data-share-label]");
    const url = button.dataset.shareUrl || window.location.href;
    const title = button.dataset.shareTitle || document.title;
    const text = button.dataset.shareText || `Check out ${title}`;

    const flashLabel = (nextText) => {
      if (!defaultLabel) {
        return;
      }

      const original = defaultLabel.textContent;
      defaultLabel.textContent = nextText;

      window.setTimeout(() => {
        defaultLabel.textContent = original;
      }, 1600);
    };

    button.addEventListener("click", async () => {
      if (navigator.share) {
        try {
          await navigator.share({ title, text, url });
          flashLabel("Shared");
          return;
        } catch (error) {
          if (error && error.name === "AbortError") {
            return;
          }
        }
      }

      if (navigator.clipboard && navigator.clipboard.writeText) {
        try {
          await navigator.clipboard.writeText(url);
          flashLabel("Copied");
          return;
        } catch (error) {
        }
      }

      window.prompt("Copy this page link", url);
    });
  });
</script>
</body>
</html>
