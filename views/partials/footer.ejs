<script>
  document.querySelectorAll("[data-link-builder]").forEach((builder) => {
    const revealButton = builder.querySelector("[data-reveal-links]");
    const rows = Array.from(builder.querySelectorAll("[data-link-row]"));

    const syncRevealButton = () => {
      if (!revealButton) {
        return;
      }

      const hiddenRows = rows.filter((row) => row.classList.contains("is-hidden-empty"));
      revealButton.hidden = hiddenRows.length === 0;
    };

    revealButton?.addEventListener("click", () => {
      rows
        .filter((row) => row.classList.contains("is-hidden-empty"))
        .slice(0, 4)
        .forEach((row) => row.classList.remove("is-hidden-empty"));

      syncRevealButton();
    });

    syncRevealButton();
  });

  document.querySelectorAll("[data-share-page]").forEach((button) => {
    const defaultLabel = button.querySelector("[data-share-label]");
    const url = button.dataset.shareUrl || window.location.href;
    const title = button.dataset.shareTitle || document.title;
    const text = button.dataset.shareText || `Check out ${title}`;

    const flashLabel = (nextText) => {
      if (!defaultLabel) {
        return;
      }

      const original = defaultLabel.textContent;
      defaultLabel.textContent = nextText;

      window.setTimeout(() => {
        defaultLabel.textContent = original;
      }, 1600);
    };

    button.addEventListener("click", async () => {
      if (navigator.share) {
        try {
          await navigator.share({ title, text, url });
          flashLabel("Shared");
          return;
        } catch (error) {
          if (error && error.name === "AbortError") {
            return;
          }
        }
      }

      if (navigator.clipboard && navigator.clipboard.writeText) {
        try {
          await navigator.clipboard.writeText(url);
          flashLabel("Copied");
          return;
        } catch (error) {
        }
      }

      window.prompt("Copy this page link", url);
    });
  });
</script>
</body>
</html>
