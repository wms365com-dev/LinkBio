<%- include("partials/header") %>

<div class="site-shell">
  <header class="marketing-nav container">
    <a class="brand-mark" href="/">myurlc.com</a>
    <div class="nav-actions">
      <% if (user.can_access_studio) { %>
        <a class="btn btn-ghost" href="/studio">Back to studio</a>
      <% } %>
      <a class="btn btn-ghost" href="/studio/export">Export JSON</a>
      <a class="btn btn-ghost" href="/analytics">Analytics</a>
      <form method="POST" action="/logout">
        <button class="btn btn-secondary" type="submit">Log out</button>
      </form>
    </div>
  </header>

  <main class="container billing-layout">
    <section class="card billing-main">
      <p class="eyebrow"><%= user.has_lifetime_plan ? 'Founder plan active' : (user.has_bonus_access ? 'Referral rewards active' : (trialExpired ? 'Trial ended' : 'Upgrade anytime')) %></p>
      <h1><%= user.has_lifetime_plan ? 'You locked in a founder account for life.' : (user.has_bonus_access ? 'Your referrals are earning extra service time.' : (trialExpired ? 'Continue your page with a paid plan.' : 'Keep your page ready before trial ends.')) %></h1>
      <p class="lead">
        <% if (user.has_lifetime_plan) { %>
          You are one of the first <%= founderOffer.limit %> users, so your myurlc.com account stays active for life.
          <% if (user.founder_slot_number) { %>
            Founder slot #<%= user.founder_slot_number %>.
          <% } %>
        <% } else if (trialExpired) { %>
          <% if (user.has_bonus_access) { %>
            Your trial ended on <%= user.formatted_trial_end %>, but referral rewards keep your access live until <%= user.formatted_access_end %>.
          <% } else { %>
            Your 7-day free trial ended on <%= user.formatted_trial_end %>. Upgrade to keep editing and publishing your page.
          <% } %>
        <% } else if (user.has_active_plan) { %>
          Your plan is active through <%= user.formatted_access_end %>. Billing is handled and your page can stay live.
        <% } else if (user.has_bonus_access) { %>
          Your referral rewards are covering service through <%= user.formatted_access_end %>. You can keep editing without paying yet.
        <% } else { %>
          Your trial ends on <%= user.formatted_trial_end %>. Upgrade now so your page stays live without interruption.
        <% } %>
      </p>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <% if (info) { %>
        <div class="success"><%= info %></div>
      <% } %>

      <div class="pricing-card">
        <div>
          <p class="eyebrow">Plan</p>
          <h2><%= user.has_lifetime_plan ? 'Founding 500 Lifetime' : planName %></h2>
          <p class="section-copy"><%= user.has_lifetime_plan ? 'Customization, publishing, and ongoing access are locked in for life.' : 'Customization, publishing, and ongoing account access.' %></p>
        </div>
        <div class="pricing-amount">
          <strong><%= user.has_lifetime_plan ? '$0 forever' : planPriceDisplay %></strong>
        </div>
      </div>

      <div class="feature-list">
        <div class="feature-item">Keep editing your page after the 7-day trial</div>
        <div class="feature-item">Publish and update your page anytime</div>
        <div class="feature-item">Use custom themes, branding, and button links</div>
      </div>

      <div class="card subtle-card">
        <div class="section-header">
          <div>
            <p class="eyebrow">Referral program</p>
            <h2>Earn up to 12 free months</h2>
          </div>
        </div>
        <div class="billing-status-list">
          <div class="status-row">
            <span>Referral code</span>
            <strong><%= user.referral_code %></strong>
          </div>
          <div class="status-row">
            <span>Share link</span>
            <strong class="billing-url"><%= user.referral_share_url %></strong>
          </div>
          <div class="status-row">
            <span>Successful referrals</span>
            <strong><%= user.successful_referrals_count %></strong>
          </div>
          <div class="status-row">
            <span>Free months earned</span>
            <strong><%= user.referral_bonus_months_earned %> / <%= referralBonusMonthsMax %></strong>
          </div>
        </div>
        <p class="field-hint">Each new signup through your code adds 1 month of free service, up to a full year.</p>
      </div>

      <% if (user.has_lifetime_plan || user.has_active_plan || user.has_bonus_access) { %>
        <a class="btn" href="/studio">Open studio</a>
        <% if (billingConfigured && !user.has_active_plan && !user.has_lifetime_plan) { %>
          <form method="POST" action="/billing/create-checkout-session">
            <button class="btn btn-secondary" type="submit">Upgrade now</button>
          </form>
        <% } %>
      <% } else if (billingConfigured) { %>
        <form method="POST" action="/billing/create-checkout-session">
          <button class="btn" type="submit"><%= trialExpired ? 'Pay and continue' : 'Upgrade now' %></button>
        </form>
      <% } else { %>
        <div class="notice">
          Stripe billing is not configured yet. You can activate accounts manually or wire in your Stripe price first.
        </div>
      <% } %>
    </section>

    <aside class="card billing-side">
      <p class="eyebrow">Account status</p>
      <h2><%= user.has_lifetime_plan ? 'Founder account' : (user.has_active_plan ? 'Active plan' : (user.has_bonus_access ? 'Referral access' : (trialExpired ? 'Payment required' : 'Trial running'))) %></h2>
      <div class="billing-status-list">
        <div class="status-row">
          <span>Status</span>
          <strong><%= user.billing_status %></strong>
        </div>
        <% if (user.has_lifetime_plan) { %>
          <div class="status-row">
            <span>Founder slot</span>
            <strong>#<%= user.founder_slot_number %></strong>
          </div>
        <% } %>
        <div class="status-row">
          <span>Trial end</span>
          <strong><%= user.formatted_trial_end %></strong>
        </div>
        <% if (user.has_lifetime_plan) { %>
          <div class="status-row">
            <span>Access</span>
            <strong>Lifetime</strong>
          </div>
        <% } else if (user.has_bonus_access) { %>
          <div class="status-row">
            <span>Referral access until</span>
            <strong><%= user.formatted_access_end %></strong>
          </div>
          <div class="status-row">
            <span>Bonus days remaining</span>
            <strong><%= user.referral_days_remaining %></strong>
          </div>
        <% } else if (!user.has_active_plan) { %>
          <div class="status-row">
            <span>Days remaining</span>
            <strong><%= user.trial_days_remaining %></strong>
          </div>
        <% } else { %>
          <div class="status-row">
            <span>Paid access until</span>
            <strong><%= user.formatted_access_end %></strong>
          </div>
        <% } %>
        <% if (order && order.public_url) { %>
          <div class="status-row">
            <span>Page URL</span>
            <strong class="billing-url"><%= order.public_url %></strong>
          </div>
        <% } %>
      </div>

      <div class="card subtle-card analytics-snapshot-card analytics-snapshot-card-tight">
        <div class="section-header compact-header">
          <div>
            <p class="eyebrow">Analytics snapshot</p>
            <h3>Last 30 days</h3>
          </div>
          <a class="text-link" href="/analytics">Open reports</a>
        </div>
        <div class="grid two analytics-snapshot-grid analytics-snapshot-grid-compact">
          <div class="analytics-mini-stat">
            <span>Views</span>
            <strong><%= analyticsSnapshot.summary_30d.page_views %></strong>
          </div>
          <div class="analytics-mini-stat">
            <span>Clicks</span>
            <strong><%= analyticsSnapshot.summary_30d.link_clicks %></strong>
          </div>
          <div class="analytics-mini-stat">
            <span>Visitors</span>
            <strong><%= analyticsSnapshot.summary_30d.unique_visitors %></strong>
          </div>
          <div class="analytics-mini-stat">
            <span>Leads</span>
            <strong><%= analyticsSnapshot.summary_30d.leads %></strong>
          </div>
        </div>
      </div>
    </aside>
  </main>
</div>

<%- include("partials/footer") %>
