<%- include("partials/header") %>

<div class="site-shell">
  <header class="simple-nav container">
    <a class="brand-mark" href="/admin">Admin Dashboard</a>
    <a class="text-link" href="/admin">Back to orders</a>
  </header>

  <main class="container narrow-wide">
    <section class="card">
      <div class="section-header">
        <div>
          <p class="eyebrow">Order #<%= order.id %></p>
          <h1><%= order.business_name || "Untitled order" %></h1>
        </div>
        <div class="actions">
          <a class="btn btn-ghost" href="<%= order.public_url %>" target="_blank" rel="noreferrer">Preview URL</a>
          <% if (order.is_published) { %>
            <form method="POST" action="/admin/order/<%= order.id %>/unpublish">
              <button class="btn btn-secondary" type="submit">Unpublish</button>
            </form>
          <% } else { %>
            <form method="POST" action="/admin/order/<%= order.id %>/publish">
              <button class="btn" type="submit">Publish now</button>
            </form>
          <% } %>
        </div>
      </div>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>
      <% if (info) { %>
        <div class="success"><%= info %></div>
      <% } %>

      <datalist id="link-label-suggestions">
        <% socialLinkSuggestions.forEach(option => { %>
          <option value="<%= option.label %>"></option>
        <% }) %>
        <option value="Website"></option>
        <option value="Store"></option>
        <option value="Book Now"></option>
        <option value="Portfolio"></option>
        <option value="Menu"></option>
      </datalist>

      <% if (ownerUser) { %>
        <div class="card subtle-card">
          <div class="section-header">
            <div>
              <p class="eyebrow">Customer account</p>
              <h2><%= ownerUser.name %></h2>
            </div>
            <div class="actions">
              <% if (ownerUser.has_active_plan) { %>
                <form method="POST" action="/admin/customer/<%= ownerUser.id %>/deactivate">
                  <button class="btn btn-secondary" type="submit">Mark payment required</button>
                </form>
              <% } else { %>
                <form method="POST" action="/admin/customer/<%= ownerUser.id %>/activate">
                  <button class="btn" type="submit">Activate paid access</button>
                </form>
              <% } %>
            </div>
          </div>
          <div class="billing-status-list">
            <div class="status-row">
              <span>Billing</span>
              <strong><%= ownerUser.billing_status %></strong>
            </div>
            <div class="status-row">
              <span>Trial end</span>
              <strong><%= ownerUser.formatted_trial_end %></strong>
            </div>
            <div class="status-row">
              <span>Email</span>
              <strong><%= ownerUser.email %></strong>
            </div>
          </div>
        </div>
      <% } %>

      <div class="card subtle-card">
        <div class="section-header">
          <div>
            <p class="eyebrow">Insights</p>
            <h2>Clicks and leads</h2>
          </div>
        </div>
        <div class="billing-status-list">
          <div class="status-row">
            <span>Total tracked events</span>
            <strong><%= analyticsSummary.total %></strong>
          </div>
          <div class="status-row">
            <span>Link clicks</span>
            <strong><%= analyticsSummary.clicks %></strong>
          </div>
          <div class="status-row">
            <span>Lead submissions</span>
            <strong><%= recentLeads.length %></strong>
          </div>
        </div>
      </div>

      <div class="card subtle-card">
        <div class="section-header">
          <div>
            <p class="eyebrow">Safety net</p>
            <h2>Version history</h2>
            <p class="section-copy">Automatic restore points are saved before major page changes so you can roll a customer back safely.</p>
          </div>
        </div>
        <% if (pageRevisions.length > 0) { %>
          <div class="analytics-list">
            <% pageRevisions.forEach(revision => { %>
              <div class="analytics-list-row revision-list-row">
                <div class="analytics-list-copy">
                  <strong><%= revision.reason %></strong>
                  <small>
                    <%= revision.actor_label %> | <%= revision.snapshot_status %> | @<%= revision.snapshot_slug %>
                  </small>
                  <small><%= revision.formatted_created_at %> | <%= revision.relative_created_at %></small>
                </div>
                <div class="actions revision-actions">
                  <form method="POST" action="/admin/order/<%= order.id %>/revisions/<%= revision.id %>/restore">
                    <button class="btn btn-ghost" type="submit">Restore</button>
                  </form>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="empty-state analytics-inline-empty">
            <p class="section-copy">Restore points will start appearing here after the first page edit or publish action.</p>
          </div>
        <% } %>
      </div>

      <% if (recentLeads.length > 0) { %>
        <div class="card subtle-card">
          <div class="section-header">
            <div>
              <p class="eyebrow">Recent leads</p>
              <h2>Latest messages</h2>
            </div>
          </div>
          <div class="lead-list">
            <% recentLeads.forEach(lead => { %>
              <article class="lead-item">
                <strong><%= lead.name %></strong>
                <span><%= lead.email %></span>
                <p><%= lead.message %></p>
                <small><%= lead.formatted_created_at %></small>
              </article>
            <% }) %>
          </div>
        </div>
      <% } %>

      <form method="POST" action="/admin/order/<%= order.id %>/update" enctype="multipart/form-data" class="form-stack">
        <div class="form-grid two">
          <div>
            <label>Email</label>
            <input name="email" type="email" value="<%= order.email %>" required />
          </div>
          <div>
            <label>Full name</label>
            <input name="full_name" value="<%= order.full_name %>" required />
          </div>
        </div>

        <div class="form-grid two">
          <div>
            <label>Business name</label>
            <input name="business_name" value="<%= order.business_name %>" required />
          </div>
          <div>
            <label>Username</label>
            <input name="slug" value="<%= order.slug %>" required pattern="[a-z0-9]+(?:-[a-z0-9]+)*" minlength="3" maxlength="32" autocapitalize="off" spellcheck="false" />
            <p class="field-hint">Use 3-32 lowercase letters, numbers, or hyphens only. Usernames are unique across all pages.</p>
          </div>
        </div>

        <div class="section-header compact-header">
          <div>
            <h2>Bio</h2>
            <p class="section-copy">Update the about section shown on the public page.</p>
          </div>
        </div>
        <textarea name="bio" rows="4"><%= order.bio %></textarea>

        <div class="form-grid two">
          <div>
            <label>Phone or WhatsApp</label>
            <input name="phone" value="<%= order.phone %>" />
          </div>
          <div>
            <label>Accent color</label>
            <input name="accent_color" type="color" value="<%= order.accent_color %>" />
          </div>
        </div>

        <div class="form-grid three admin-grid">
          <div>
            <label>Theme</label>
            <select name="theme">
              <% themeOptions.forEach(option => { %>
                <option value="<%= option.value %>" <%= order.theme === option.value ? "selected" : "" %>><%= option.label %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label>Status</label>
            <select name="status">
              <% statusOptions.forEach(option => { %>
                <option value="<%= option %>" <%= order.status === option ? "selected" : "" %>><%= option %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label>Payment status</label>
            <select name="payment_status">
              <% paymentStatusOptions.forEach(option => { %>
                <option value="<%= option %>" <%= order.payment_status === option ? "selected" : "" %>><%= option %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="form-grid two">
          <div>
            <label>Profile photo or short video</label>
            <input name="profile_media" type="file" accept="image/*,video/*" />

            <% if (order.profile_media) { %>
              <div class="asset-preview-card">
                <% if (order.profile_media_type === "video") { %>
                  <video class="asset-preview-media" src="<%= order.profile_media %>" muted loop playsinline controls></video>
                <% } else { %>
                  <img class="asset-preview-media" src="<%= order.profile_media %>" alt="Profile media" />
                <% } %>
              </div>
              <label class="checkbox-row">
                <input type="checkbox" name="remove_profile_media" value="1" />
                Remove current profile media
              </label>
            <% } %>
          </div>

          <div>
            <label>Background image</label>
            <input name="background_image" type="file" accept="image/*" />

            <% if (order.background_image) { %>
              <div class="asset-preview-card">
                <img class="asset-preview-media asset-preview-wide" src="<%= order.background_image %>" alt="Background image" />
              </div>
              <label class="checkbox-row">
                <input type="checkbox" name="remove_background_image" value="1" />
                Remove current background image
              </label>
            <% } %>
          </div>
        </div>

        <div class="feature-toggle">
          <label class="checkbox-row">
            <input type="checkbox" name="lead_form_enabled" value="1" <%= order.lead_form_enabled ? 'checked' : '' %> />
            Enable lead capture form
          </label>
        </div>

        <label>Lead form headline</label>
        <input name="lead_form_prompt" value="<%= order.lead_form_prompt %>" placeholder="Send me a quick message" />

        <div class="section-header">
          <div>
            <h2>Buttons and links</h2>
            <p class="section-copy">Use the fixed sections only. Social links become icons; the others stay as grouped buttons.</p>
          </div>
        </div>

        <div class="link-builder" data-link-builder>
          <% order.links.forEach((link, index) => { %>
            <% const suggestion = socialLinkSuggestions[index] || socialLinkSuggestions[socialLinkSuggestions.length - 1]; %>
            <% const hiddenRow = index >= initialVisibleLinkRows && !link.label && !link.url; %>
            <div class="link-row link-row-rich <%= hiddenRow ? 'is-hidden-empty' : '' %>" data-link-row>
              <button class="link-drag-handle" type="button" data-link-drag-handle aria-label="Drag to reorder links" title="Drag to reorder links">::</button>
              <select name="link_section">
                <% linkSectionOptions.forEach(option => { %>
                  <option value="<%= option.value %>" <%= link.section === option.value ? 'selected' : '' %>><%= option.label %></option>
                <% }) %>
              </select>
              <input name="link_label" value="<%= link.label %>" placeholder="<%= suggestion.label %>" list="link-label-suggestions" />
              <input name="link_url" value="<%= link.url %>" placeholder="https://<%= suggestion.placeholder %>" />
            </div>
          <% }) %>

          <div class="link-builder-tools">
            <button class="btn btn-ghost" type="button" data-reveal-links>Show more links</button>
            <p class="field-hint">Reveal extra rows when this customer needs more links.</p>
          </div>
        </div>

        <button class="btn" type="submit">Save changes</button>
      </form>
    </section>
  </main>
</div>

<%- include("partials/footer") %>
