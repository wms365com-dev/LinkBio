<%- include("partials/header") %>

<div class="site-shell">
  <header class="marketing-nav container">
    <a class="brand-mark" href="/">myurlc.com</a>
    <div class="nav-actions">
      <% if (order && order.public_url) { %>
        <a class="btn btn-ghost" href="<%= order.public_url %>" target="_blank" rel="noreferrer">Open page</a>
      <% } %>
      <form method="POST" action="/logout">
        <button class="btn btn-secondary" type="submit">Log out</button>
      </form>
    </div>
  </header>

  <main class="container studio-layout">
    <section class="card studio-panel">
      <div class="section-header">
        <div>
          <p class="eyebrow">Page studio</p>
          <h1>Customize your link page</h1>
          <p class="section-copy">
            Add media, organize links into built-in sections, and publish whenever the page feels ready.
          </p>
        </div>
        <div class="studio-meta">
          <span class="pill <%= order && order.is_published ? 'pill-live' : '' %>">
            <%= order && order.is_published ? 'Live' : 'Draft' %>
          </span>
          <% if (order && order.public_url) { %>
            <span class="studio-url"><%= order.public_url %></span>
          <% } %>
        </div>
      </div>

      <% if (user.has_lifetime_plan) { %>
        <div class="success founder-status-card">
          You are in the founding 100. This account is free for life.
          <% if (user.founder_slot_number) { %>
            <strong>Founder slot #<%= user.founder_slot_number %>.</strong>
          <% } %>
        </div>
      <% } else if (!user.has_active_plan) { %>
        <div class="<%= user.has_bonus_access ? 'success' : (user.trial_expired ? 'error' : 'notice') %>">
          <% if (user.has_bonus_access) { %>
            Referral rewards are covering your account through <strong><%= user.formatted_access_end %></strong>.
            <a class="text-link" href="/billing">View referral details</a>
          <% } else if (user.trial_expired) { %>
            Your <%= trialDays %>-day free trial ended on <%= user.formatted_trial_end %>. Upgrade to continue editing.
          <% } else { %>
            Trial active. <strong><%= user.trial_days_remaining %></strong> day<%= user.trial_days_remaining === 1 ? '' : 's' %> left.
            <a class="text-link" href="/billing">Upgrade now</a>
          <% } %>
        </div>
      <% } else { %>
        <div class="success">
          Your paid plan is active.
        </div>
      <% } %>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <% if (info) { %>
        <div class="success"><%= info %></div>
      <% } %>

      <nav class="mobile-studio-nav" aria-label="Jump to studio sections">
        <a class="mobile-studio-nav-link" href="#studio-profile">Profile</a>
        <a class="mobile-studio-nav-link" href="#studio-style">Style</a>
        <a class="mobile-studio-nav-link" href="#studio-links">Links</a>
        <a class="mobile-studio-nav-link" href="#studio-publish">Publish</a>
      </nav>

      <div class="card subtle-card referral-card">
        <div class="section-header">
          <div>
            <p class="eyebrow">Referral program</p>
            <h2>Earn free months</h2>
          </div>
          <a class="text-link" href="/billing">Open billing</a>
        </div>
        <div class="billing-status-list">
          <div class="status-row">
            <span>Referral code</span>
            <strong><%= user.referral_code %></strong>
          </div>
          <div class="status-row">
            <span>Share link</span>
            <strong class="billing-url"><%= user.referral_share_url %></strong>
          </div>
          <div class="status-row">
            <span>Successful referrals</span>
            <strong><%= user.successful_referrals_count %></strong>
          </div>
          <div class="status-row">
            <span>Free months earned</span>
            <strong><%= user.referral_bonus_months_earned %> / <%= referralBonusMonthsMax %></strong>
          </div>
        </div>
        <p class="field-hint">Each new signup through your referral link adds 1 free month of service, up to 12 months total.</p>
      </div>

      <datalist id="link-label-suggestions">
        <% socialLinkSuggestions.forEach(option => { %>
          <option value="<%= option.label %>"></option>
        <% }) %>
        <option value="Website"></option>
        <option value="Store"></option>
        <option value="Book Now"></option>
        <option value="Portfolio"></option>
        <option value="Menu"></option>
        <option value="Call Now"></option>
      </datalist>

      <form method="POST" action="/studio" enctype="multipart/form-data" class="form-stack">
        <div class="form-grid two studio-section" id="studio-profile">
          <div>
            <label>Full name</label>
            <input name="full_name" value="<%= values.full_name %>" required />
          </div>
          <div>
            <label>Business name</label>
            <input name="business_name" value="<%= values.business_name %>" required />
          </div>
        </div>

        <div class="form-grid two">
          <div>
            <label>Account email</label>
            <input value="<%= values.email %>" disabled />
            <p class="field-hint">Email changes are not part of this MVP.</p>
          </div>
          <div>
            <label>Public username</label>
            <input name="slug" value="<%= values.slug %>" placeholder="your-brand" pattern="[a-z0-9]+(?:-[a-z0-9]+)*" minlength="3" maxlength="32" autocapitalize="off" spellcheck="false" />
            <p class="field-hint">Use 3-32 lowercase letters, numbers, or hyphens only. This becomes your page URL and must be unique.</p>
          </div>
        </div>

        <div class="section-header compact-header">
          <div>
            <h2>Bio</h2>
            <p class="section-copy">Add a short about section so visitors know who you are and what you do.</p>
          </div>
        </div>
        <textarea name="bio" rows="4" placeholder="Tell visitors what you do."><%= values.bio %></textarea>

        <div class="form-grid two studio-section" id="studio-style">
          <div>
            <label>Phone or WhatsApp</label>
            <input name="phone" value="<%= values.phone %>" placeholder="+1 555 555 5555" />
          </div>
          <div>
            <label>Accent color</label>
            <input name="accent_color" type="color" value="<%= values.accent_color %>" />
          </div>
        </div>

        <label>Theme</label>
        <select name="theme">
          <% themeOptions.forEach(option => { %>
            <option value="<%= option.value %>" <%= values.theme === option.value ? 'selected' : '' %>><%= option.label %></option>
          <% }) %>
        </select>

        <div class="form-grid two">
          <div>
            <label>Profile photo or short video</label>
            <input name="profile_media" type="file" accept="image/*,video/*" />
            <p class="field-hint">Use an image or a muted loop-friendly video to make the top of the page feel alive.</p>

            <% if (values.profile_media) { %>
              <div class="asset-preview-card">
                <% if (values.profile_media_type === "video") { %>
                  <video class="asset-preview-media" src="<%= values.profile_media %>" muted loop playsinline controls></video>
                <% } else { %>
                  <img class="asset-preview-media" src="<%= values.profile_media %>" alt="Current profile media" />
                <% } %>
              </div>
              <label class="checkbox-row">
                <input type="checkbox" name="remove_profile_media" value="1" />
                Remove current profile media
              </label>
            <% } %>
          </div>

          <div>
            <label>Background image</label>
            <input name="background_image" type="file" accept="image/*" />
            <p class="field-hint">Optional full-page backdrop behind the card.</p>

            <% if (values.background_image) { %>
              <div class="asset-preview-card">
                <img class="asset-preview-media asset-preview-wide" src="<%= values.background_image %>" alt="Current background image" />
              </div>
              <label class="checkbox-row">
                <input type="checkbox" name="remove_background_image" value="1" />
                Remove current background image
              </label>
            <% } %>
          </div>
        </div>

        <div class="feature-toggle">
          <label class="checkbox-row">
            <input type="checkbox" name="lead_form_enabled" value="1" <%= values.lead_form_enabled ? 'checked' : '' %> />
            Turn on lead capture form
          </label>
          <p class="field-hint">Visitors can send their name, email, and message straight from the page.</p>
        </div>

        <label>Lead form headline</label>
        <input name="lead_form_prompt" value="<%= values.lead_form_prompt %>" placeholder="Send me a quick message" />

        <div class="section-header studio-section" id="studio-links">
          <div>
            <h2>Buttons and links</h2>
            <p class="section-copy">Choose one of the built-in sections for every link. Social links render as icons under the profile, while the other sections show full buttons.</p>
          </div>
        </div>

        <div class="link-builder" data-link-builder>
          <% values.links.forEach((link, index) => { %>
            <% const suggestion = socialLinkSuggestions[index] || socialLinkSuggestions[socialLinkSuggestions.length - 1]; %>
            <% const hiddenRow = index >= initialVisibleLinkRows && !link.label && !link.url; %>
            <div class="link-row link-row-rich <%= hiddenRow ? 'is-hidden-empty' : '' %>" data-link-row>
              <select name="link_section">
                <% linkSectionOptions.forEach(option => { %>
                  <option value="<%= option.value %>" <%= link.section === option.value ? 'selected' : '' %>><%= option.label %></option>
                <% }) %>
              </select>
              <input name="link_label" value="<%= link.label %>" placeholder="<%= suggestion.label %>" list="link-label-suggestions" />
              <input name="link_url" value="<%= link.url %>" placeholder="https://<%= suggestion.placeholder %>" />
            </div>
          <% }) %>

          <div class="link-builder-tools">
            <button class="btn btn-ghost" type="button" data-reveal-links>Show more links</button>
            <p class="field-hint">Start with <%= initialVisibleLinkRows %> rows and reveal more as needed, up to <%= maxLinks %> links.</p>
          </div>
        </div>

        <div class="actions studio-actions studio-section" id="studio-publish">
          <button class="btn btn-secondary" type="submit" name="intent" value="save_draft">Save draft</button>
          <% if (order && order.is_published) { %>
            <button class="btn btn-ghost" type="submit" name="intent" value="unpublish">Unpublish</button>
            <button class="btn" type="submit" name="intent" value="publish">Update live page</button>
          <% } else { %>
            <button class="btn" type="submit" name="intent" value="publish">Publish page</button>
          <% } %>
        </div>
        <p class="field-hint">Saving a draft keeps the page private until you publish it.</p>
      </form>
    </section>

    <aside class="card studio-preview-panel">
      <div class="section-header">
        <div>
          <p class="eyebrow">Preview</p>
          <h2>How your page looks</h2>
        </div>
      </div>

      <div class="studio-preview-shell">
        <% const previewContactActions = buildPhoneContactActions(preview.phone); %>
        <% const previewSubscribeHref = preview.lead_form_enabled ? '#preview-subscribe' : '#preview-join' %>
        <% const showPreviewSectionLabels = preview.link_sections.length > 1; %>
        <% const previewVisibleName = preview.business_name || preview.full_name || preview.slug; %>
        <% const showPreviewVisibleName = previewVisibleName && previewVisibleName.toLowerCase() !== preview.slug.toLowerCase(); %>
        <div class="profile-page profile-page-embedded profile-theme-<%= preview.theme %>" style="--accent:<%= preview.accent_color %>;">
          <% if (preview.background_image) { %>
            <div class="profile-backdrop" style="background-image:url('<%= preview.background_image %>');"></div>
          <% } %>
          <div class="profile-orb orb-a"></div>
          <div class="profile-orb orb-b"></div>

          <div class="profile-shell">
            <div class="profile-topbar">
              <div class="profile-action-button profile-home-link profile-home-link-static" aria-hidden="true">
                <span class="icon-svg"><%- iconSvg("brand") %></span>
              </div>
              <div class="profile-top-actions">
                <a class="profile-action-button profile-action-button-static" href="<%= previewSubscribeHref %>">
                  <span class="icon-svg"><%- iconSvg("subscribe") %></span>
                </a>
                <button class="profile-action-button profile-action-button-ghost profile-action-button-static" type="button">
                  <span class="icon-svg"><%- iconSvg("share") %></span>
                </button>
              </div>
            </div>

            <div class="profile-card">
              <div class="profile-media-shell">
                <% if (preview.profile_media) { %>
                  <% if (preview.profile_media_type === "video") { %>
                    <video class="avatar avatar-video" src="<%= preview.profile_media %>" muted loop autoplay playsinline></video>
                  <% } else { %>
                    <img class="avatar" src="<%= preview.profile_media %>" alt="<%= preview.business_name %>" />
                  <% } %>
                <% } else { %>
                  <div class="avatar avatar-placeholder"><span><%= (preview.business_name || 'L').charAt(0).toUpperCase() %></span></div>
                <% } %>
              </div>

              <% if (showPreviewVisibleName) { %>
                <p class="profile-display-name"><%= previewVisibleName %></p>
              <% } %>
              <h2 class="profile-handle">@<%= preview.slug %></h2>

              <p class="bio profile-bio-inline"><%= preview.bio %></p>

              <div class="section-stack">
                <% preview.link_sections.forEach(section => { %>
                  <section class="link-section-card link-section-card-flat">
                    <% if (showPreviewSectionLabels) { %>
                      <p class="profile-section-label profile-section-label-public"><%= section.label %></p>
                    <% } %>
                    <div class="profile-links">
                      <% section.links.forEach(link => { %>
                        <div class="profile-link profile-link-static">
                          <span class="profile-link-leading">
                            <span class="profile-link-icon">
                              <span class="icon-svg"><%- iconSvg(link.platform) %></span>
                            </span>
                            <span class="profile-link-copy"><%= link.label %></span>
                          </span>
                          <span class="profile-link-trailing" aria-hidden="true">
                            <span class="icon-svg"><%- iconSvg("more") %></span>
                          </span>
                        </div>
                      <% }) %>
                    </div>
                  </section>
                <% }) %>
              </div>

              <% if (preview.lead_form_enabled) { %>
                <div class="lead-preview-card" id="preview-subscribe">
                  <p class="lead-preview-title"><%= preview.lead_form_prompt %></p>
                  <div class="lead-preview-input">Name</div>
                  <div class="lead-preview-input">Email</div>
                  <div class="lead-preview-input lead-preview-textarea">Message</div>
                  <div class="lead-preview-button">Send message</div>
                </div>
              <% } %>

              <% if (previewContactActions.length > 0 || preview.social_links.length > 0) { %>
                <div class="social-strip social-strip-lower">
                  <% previewContactActions.forEach(action => { %>
                    <div class="social-icon social-icon-static social-icon-<%= action.platform %>" title="<%= action.label %>">
                      <span class="icon-svg"><%- iconSvg(action.icon) %></span>
                    </div>
                  <% }) %>
                  <% preview.social_links.forEach(link => { %>
                    <div class="social-icon social-icon-static social-icon-<%= link.platform %>" title="<%= link.label %>">
                      <span class="icon-svg"><%- iconSvg(link.platform) %></span>
                    </div>
                  <% }) %>
                </div>
              <% } %>

              <a class="profile-platform-cta profile-platform-cta-static" id="preview-join" href="#preview-join">Join <%= preview.slug %> on myurlc.com</a>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </main>
</div>

<%- include("partials/footer") %>
