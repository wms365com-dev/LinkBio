<%- include("partials/header") %>

<div class="site-shell">
  <header class="simple-nav container">
    <a class="brand-mark" href="/">LinkBio Studio</a>
    <a class="text-link" href="/buy">Back to checkout</a>
  </header>

  <main class="container narrow">
    <section class="card">
      <p class="eyebrow">Step 2 of 2</p>
      <h1>Customer intake form</h1>
      <p class="lead">Capture the brand details once, then refine and publish the page from admin.</p>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <% if (sessionId) { %>
        <div class="<%= paid ? 'success' : 'notice' %>">
          <%= paid ? 'Payment confirmed. Finish the form to create the order.' : 'Checkout session detected, but it is not marked paid yet.' %>
        </div>
      <% } %>

      <datalist id="link-label-suggestions">
        <% socialLinkSuggestions.forEach(option => { %>
          <option value="<%= option.label %>"></option>
        <% }) %>
        <option value="Website"></option>
        <option value="Store"></option>
        <option value="Book Now"></option>
        <option value="Portfolio"></option>
      </datalist>

      <form method="POST" action="/intake" enctype="multipart/form-data" class="form-stack">
        <input type="hidden" name="session_id" value="<%= sessionId %>" />

        <div class="form-grid two">
          <div>
            <label>Email</label>
            <input name="email" type="email" value="<%= values.email %>" required />
          </div>
          <div>
            <label>Full name</label>
            <input name="full_name" value="<%= values.full_name %>" required />
          </div>
        </div>

        <div class="form-grid two">
          <div>
            <label>Business name</label>
            <input name="business_name" value="<%= values.business_name %>" required />
          </div>
          <div>
            <label>Preferred username</label>
            <input name="slug" value="<%= values.slug %>" placeholder="my-brand" pattern="[a-z0-9]+(?:-[a-z0-9]+)*" minlength="3" maxlength="32" autocapitalize="off" spellcheck="false" />
            <p class="field-hint">Use 3-32 lowercase letters, numbers, or hyphens only. If it is taken, you will need to choose another one.</p>
          </div>
        </div>

        <div class="section-header compact-header">
          <div>
            <h2>Bio</h2>
            <p class="section-copy">Add a short description for the public page.</p>
          </div>
        </div>
        <textarea name="bio" rows="4" placeholder="Tell people what you do."><%= values.bio %></textarea>

        <div class="form-grid two">
          <div>
            <label>Phone or WhatsApp</label>
            <input name="phone" value="<%= values.phone %>" placeholder="+1 555 555 5555" />
          </div>
          <div>
            <label>Accent color</label>
            <input name="accent_color" type="color" value="<%= values.accent_color %>" />
          </div>
        </div>

        <label>Theme</label>
        <select name="theme">
          <% themeOptions.forEach(option => { %>
            <option value="<%= option.value %>" <%= values.theme === option.value ? "selected" : "" %>><%= option.label %></option>
          <% }) %>
        </select>

        <div class="form-grid two">
          <div>
            <label>Profile photo or short video</label>
            <input name="profile_media" type="file" accept="image/*,video/*" />
          </div>
          <div>
            <label>Background image</label>
            <input name="background_image" type="file" accept="image/*" />
          </div>
        </div>

        <div class="section-header">
          <div>
            <h2>Buttons and links</h2>
            <p class="section-copy">Pick from the built-in sections only. Social links become icons, while the other sections become button groups.</p>
          </div>
        </div>

        <div class="link-builder" data-link-builder>
          <% values.links.forEach((link, index) => { %>
            <% const suggestion = socialLinkSuggestions[index] || socialLinkSuggestions[socialLinkSuggestions.length - 1]; %>
            <% const hiddenRow = index >= initialVisibleLinkRows && !link.label && !link.url; %>
            <div class="link-row link-row-rich <%= hiddenRow ? 'is-hidden-empty' : '' %>" data-link-row>
              <select name="link_section">
                <% linkSectionOptions.forEach(option => { %>
                  <option value="<%= option.value %>" <%= link.section === option.value ? 'selected' : '' %>><%= option.label %></option>
                <% }) %>
              </select>
              <input name="link_label" value="<%= link.label %>" placeholder="<%= suggestion.label %>" list="link-label-suggestions" />
              <input name="link_url" value="<%= link.url %>" placeholder="https://<%= suggestion.placeholder %>" />
            </div>
          <% }) %>

          <div class="link-builder-tools">
            <button class="btn btn-ghost" type="button" data-reveal-links>Show more links</button>
            <p class="field-hint">Reveal extra rows when the customer needs more buttons.</p>
          </div>
        </div>

        <button class="btn" type="submit">Submit order</button>
      </form>
    </section>
  </main>
</div>

<%- include("partials/footer") %>
