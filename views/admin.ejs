<%- include("partials/header") %>

<div class="site-shell">
  <header class="marketing-nav container">
    <a class="brand-mark" href="/">myurlc.com</a>
    <div class="nav-actions">
      <a class="btn btn-ghost" href="/buy">New order</a>
      <form method="POST" action="/admin/logout">
        <button class="btn btn-secondary" type="submit">Logout</button>
      </form>
    </div>
  </header>

  <main class="container">
    <section class="grid four stats-grid">
      <article class="card stat-card">
        <span>Total orders</span>
        <strong><%= stats.total %></strong>
      </article>
      <article class="card stat-card">
        <span>Published</span>
        <strong><%= stats.published %></strong>
      </article>
      <article class="card stat-card">
        <span>Paid</span>
        <strong><%= stats.paid %></strong>
      </article>
      <article class="card stat-card">
        <span>Not live yet</span>
        <strong><%= stats.draft %></strong>
      </article>
      <article class="card stat-card">
        <span>Total clicks</span>
        <strong><%= stats.clicks %></strong>
      </article>
      <article class="card stat-card">
        <span>Leads</span>
        <strong><%= stats.leads %></strong>
      </article>
      <article class="card stat-card">
        <span>Support tickets</span>
        <strong><%= stats.tickets %></strong>
      </article>
      <article class="card stat-card">
        <span>Feedback posts</span>
        <strong><%= stats.feedbackPosts %></strong>
      </article>
      <article class="card stat-card">
        <span>Users</span>
        <strong><%= stats.users %></strong>
      </article>
      <article class="card stat-card">
        <span>Referral months</span>
        <strong><%= stats.referralMonths %></strong>
      </article>
      <article class="card stat-card">
        <span>Founder members</span>
        <strong><%= stats.founderMembers %></strong>
      </article>
      <article class="card stat-card">
        <span>Founder spots left</span>
        <strong><%= stats.founderRemaining %></strong>
      </article>
    </section>

    <section class="card">
      <div class="section-header">
        <div>
          <p class="eyebrow">Public roadmap</p>
          <h2>Recent feedback</h2>
        </div>
      </div>

      <div class="lead-list">
        <% if (!recentFeedbackPosts || recentFeedbackPosts.length === 0) { %>
          <div class="empty-state">
            <h3>No feedback yet</h3>
            <p>Public feedback posts will show up here for review and status updates.</p>
          </div>
        <% } %>

        <% (recentFeedbackPosts || []).forEach(post => { %>
          <article class="lead-item">
            <span><strong>#<%= post.id %></strong> - <%= post.category_label %> - <%= post.status_label %></span>
            <strong><%= post.title %></strong>
            <small><%= post.author.visible_name %> - <%= post.relative_created_at %></small>
            <p><%= post.body %></p>
            <small><%= post.likes_count %> likes - <%= post.comments_count %> comments</small>
            <div class="actions">
              <form method="POST" action="/admin/feedback/<%= post.id %>/status">
                <select name="status">
                  <option value="under_review" <%= post.status === 'under_review' ? 'selected' : '' %>>Under review</option>
                  <option value="planned" <%= post.status === 'planned' ? 'selected' : '' %>>Planned</option>
                  <option value="in_progress" <%= post.status === 'in_progress' ? 'selected' : '' %>>In progress</option>
                  <option value="shipped" <%= post.status === 'shipped' ? 'selected' : '' %>>Shipped</option>
                  <option value="hidden" <%= post.status === 'hidden' ? 'selected' : '' %>>Hidden</option>
                </select>
                <button class="btn" type="submit">Save status</button>
              </form>
            </div>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="card">
      <div class="section-header">
        <div>
          <p class="eyebrow">Support queue</p>
          <h2>Recent tickets</h2>
        </div>
      </div>

      <div class="lead-list">
        <% if (!recentSupportTickets || recentSupportTickets.length === 0) { %>
          <div class="empty-state">
            <h3>No tickets yet</h3>
            <p>Bug reports and help requests sent to support will show up here.</p>
          </div>
        <% } %>

        <% (recentSupportTickets || []).forEach(ticket => { %>
          <article class="lead-item">
            <span><strong>#<%= ticket.id %></strong> • <%= ticket.category %> • <%= ticket.status %></span>
            <strong><%= ticket.subject %></strong>
            <small><%= ticket.name %> • <a class="text-link" href="mailto:<%= ticket.email %>"><%= ticket.email %></a></small>
            <% if (ticket.page_url) { %>
              <small><%= ticket.page_url %></small>
            <% } %>
            <p><%= ticket.message %></p>
            <div class="actions">
              <a class="btn btn-secondary" href="mailto:<%= supportEmail %>?subject=Re:%20<%= encodeURIComponent(ticket.subject) %>&body=<%= encodeURIComponent(`Ticket #${ticket.id} from ${ticket.name} (${ticket.email})`) %>">Reply</a>
              <% if (ticket.status !== 'resolved') { %>
                <form method="POST" action="/admin/ticket/<%= ticket.id %>/resolve">
                  <button class="btn" type="submit">Mark resolved</button>
                </form>
              <% } %>
            </div>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="card table-wrap">
      <div class="section-header">
        <div>
          <p class="eyebrow">Orders</p>
          <h1>Admin dashboard</h1>
        </div>
      </div>

      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Business</th>
            <th>Customer</th>
            <th>Links</th>
            <th>Payment</th>
            <th>Status</th>
            <th>Created</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% if (orders.length === 0) { %>
            <tr>
              <td colspan="8">No orders yet.</td>
            </tr>
          <% } %>

          <% orders.forEach(order => { %>
            <tr>
              <td><%= order.id %></td>
              <td>
                <strong><%= order.business_name %></strong>
                <div class="table-meta"><%= order.slug %></div>
              </td>
              <td>
                <%= order.full_name %>
                <div class="table-meta"><%= order.email %></div>
              </td>
              <td><%= order.links.length %></td>
              <td><span class="pill"><%= order.payment_status %></span></td>
              <td><span class="pill <%= order.is_published ? 'pill-live' : '' %>"><%= order.status %></span></td>
              <td><%= order.created_at %></td>
              <td><a class="table-link" href="/admin/order/<%= order.id %>">Open</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </main>
</div>

<%- include("partials/footer") %>
