<%- include("partials/header") %>

<div class="site-shell">
  <header class="simple-nav container">
    <a class="brand-mark" href="/">LinkBio Studio</a>
    <a class="text-link" href="/login">Already have an account?</a>
  </header>

  <main class="container auth-grid">
    <section class="card auth-copy-card">
      <p class="eyebrow">Self-serve launch</p>
      <h1>Sign up and start building your page.</h1>
      <p class="lead">
        Create an account, claim your slug, and customize your link page without waiting for manual setup.
        Every account starts with a <%= trialDays %>-day free trial.
      </p>
      <div class="feature-list">
        <div class="feature-item">Pick a theme and accent color</div>
        <div class="feature-item">Upload your photo or logo</div>
        <div class="feature-item">Add your buttons and publish when ready</div>
      </div>
    </section>

    <section class="card auth-form-card">
      <p class="eyebrow">Create account</p>
      <h2>Start your LinkBio</h2>
      <p class="field-hint"><%= trialDays %>-day free trial, then <%= planPriceDisplay %>.</p>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <form method="POST" action="/signup" class="form-stack">
        <div class="form-grid two">
          <div>
            <label>Full name</label>
            <input name="full_name" value="<%= values.full_name || '' %>" required />
          </div>
          <div>
            <label>Business name</label>
            <input name="business_name" value="<%= values.business_name || '' %>" required />
          </div>
        </div>

        <label>Email</label>
        <input name="email" type="email" value="<%= values.email || '' %>" required />

        <label>Password</label>
        <input name="password" type="password" minlength="8" required />
        <p class="field-hint">Use at least 8 characters.</p>

        <button class="btn" type="submit">Create account</button>
      </form>

      <p class="auth-switch">
        Already signed up?
        <a class="text-link" href="/login">Log in</a>
      </p>
    </section>
  </main>
</div>

<%- include("partials/footer") %>
