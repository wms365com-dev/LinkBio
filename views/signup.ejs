<%- include("partials/header") %>

<div class="site-shell">
  <header class="simple-nav container">
    <a class="brand-mark" href="/">myurlc.com</a>
    <a class="text-link" href="/login">Already have an account?</a>
  </header>

  <main class="container auth-grid">
    <section class="card auth-copy-card">
      <div class="founder-banner founder-banner-compact">
        <div class="founder-banner-topline">
          <span class="founder-chip">Founder 500</span>
          <span class="founder-count"><%= founderOffer.claimed %> / <%= founderOffer.limit %> claimed</span>
        </div>
        <strong>Free for the first 500 users for life!</strong>
        <p>
          <%= founderOffer.is_open
            ? `${founderOffer.remaining} founder spot${founderOffer.remaining === 1 ? "" : "s"} still open right now.`
            : "The founding 500 is full, but you can still start with the normal free trial." %>
        </p>
      </div>
      <p class="eyebrow">Self-serve launch</p>
      <h1>Sign up and start building your link-in-bio page.</h1>
      <p class="lead">
        Create an account, claim your username, and customize a search-friendly link-in-bio page without waiting for manual setup.
        The first <%= founderOffer.limit %> users get lifetime access, and everyone after that starts with a <%= trialDays %>-day free trial.
      </p>
      <div class="feature-list">
        <div class="feature-item">Pick a theme and accent color</div>
        <div class="feature-item">Upload your photo or logo</div>
        <div class="feature-item">Add your buttons and publish when ready</div>
      </div>
    </section>

    <section class="card auth-form-card">
      <p class="eyebrow">Create account</p>
      <h2>Start your myurlc.com page</h2>
      <p class="field-hint">
        <%= founderOffer.is_open
          ? `Join now and you could still lock in a free-for-life founder slot.`
          : `${trialDays}-day free trial, then ${planPriceDisplay}.` %>
      </p>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <% if (info) { %>
        <div class="success"><%= info %></div>
      <% } %>

      <form method="POST" action="/signup" class="form-stack">
        <div class="form-grid two">
          <div>
            <label>Full name</label>
            <input name="full_name" value="<%= values.full_name || '' %>" required />
          </div>
          <div>
            <label>Business name</label>
            <input name="business_name" value="<%= values.business_name || '' %>" required />
          </div>
        </div>

        <label>Email</label>
        <input name="email" type="email" value="<%= values.email || '' %>" required />

        <label>Password</label>
        <input name="password" type="password" minlength="8" required />
        <p class="field-hint">Use at least 8 characters.</p>

        <label>Referral code</label>
        <input name="referral_code" value="<%= values.referral_code || '' %>" placeholder="Optional referral code" />
        <p class="field-hint">If someone invited you, their code gives them 1 free month when you sign up.</p>

        <button class="btn" type="submit">Create account</button>
      </form>

      <p class="auth-switch">
        Already signed up?
        <a class="text-link" href="/login">Log in</a>
      </p>
    </section>
  </main>
</div>

<%- include("partials/footer") %>
