<%- include("partials/header") %>

<div class="site-shell">
  <header class="simple-nav container">
    <a class="brand-mark" href="/">myurlc.com</a>
    <a class="text-link" href="/login">Back to login</a>
  </header>

  <main class="container auth-grid auth-grid-compact">
    <section class="card auth-form-card">
      <p class="eyebrow">Account recovery</p>
      <h1>Forgot your password?</h1>
      <p class="field-hint">Enter the email for your myurlc.com account and we’ll send reset instructions.</p>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <% if (info) { %>
        <div class="success"><%= info %></div>
      <% } %>

      <form method="POST" action="/forgot-password" class="form-stack">
        <label>Email</label>
        <input name="email" type="email" value="<%= values.email || '' %>" required />

        <button class="btn" type="submit">Send reset link</button>
      </form>

      <p class="auth-switch">
        Remembered it?
        <a class="text-link" href="/login">Log in</a>
      </p>
    </section>
  </main>
</div>

<%- include("partials/footer") %>
