<%- include("partials/header") %>

<div class="site-shell">
  <header class="simple-nav container">
    <a class="brand-mark" href="/">LinkBio Studio</a>
    <a class="text-link" href="/signup">Need an account?</a>
  </header>

  <main class="container auth-grid auth-grid-compact">
    <section class="card auth-form-card">
      <p class="eyebrow">Welcome back</p>
      <h1>Log in</h1>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <% if (info) { %>
        <div class="success"><%= info %></div>
      <% } %>

      <form method="POST" action="/login" class="form-stack">
        <label>Email</label>
        <input name="email" type="email" value="<%= values.email || '' %>" required />

        <label>Password</label>
        <input name="password" type="password" required />

        <button class="btn" type="submit">Open studio</button>
      </form>

      <p class="auth-switch">
        New here?
        <a class="text-link" href="/signup">Create an account</a>
      </p>
    </section>
  </main>
</div>

<%- include("partials/footer") %>
