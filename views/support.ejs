<%- include("partials/header") %>

<div class="site-shell">
  <header class="simple-nav container">
    <a class="brand-mark" href="/">myurlc.com</a>
    <a class="text-link" href="<%= currentCustomer ? '/studio' : '/' %>"><%= currentCustomer ? 'Back to studio' : 'Back home' %></a>
  </header>

  <main class="container billing-layout">
    <section class="card billing-main">
      <p class="eyebrow">Help & bug reports</p>
      <h1>Tell us what broke or what you need help with.</h1>
      <p class="lead">
        Open a support ticket here, or email <a class="text-link" href="mailto:<%= supportEmail %>"><%= supportEmail %></a>.
        Tickets are tracked so nothing gets lost.
      </p>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <% if (info) { %>
        <div class="success"><%= info %></div>
      <% } %>

      <form method="POST" action="/support" class="form-stack">
        <div class="form-grid two">
          <div>
            <label>Name</label>
            <input name="name" value="<%= values.name || '' %>" required />
          </div>
          <div>
            <label>Email</label>
            <input name="email" type="email" value="<%= values.email || '' %>" required />
          </div>
        </div>

        <div class="form-grid two">
          <div>
            <label>Type</label>
            <select name="category">
              <option value="bug" <%= values.category === 'bug' ? 'selected' : '' %>>Bug report</option>
              <option value="help" <%= values.category === 'help' ? 'selected' : '' %>>Help request</option>
              <option value="billing" <%= values.category === 'billing' ? 'selected' : '' %>>Billing</option>
              <option value="feature" <%= values.category === 'feature' ? 'selected' : '' %>>Feature idea</option>
            </select>
          </div>
          <div>
            <label>Page or URL</label>
            <input name="page_url" value="<%= values.page_url || '' %>" placeholder="https://www.myurlc.com/studio" />
          </div>
        </div>

        <label>Subject</label>
        <input name="subject" value="<%= values.subject || '' %>" placeholder="Short summary" required />

        <label>Message</label>
        <textarea name="message" rows="8" placeholder="What happened, what you expected, and how we can reproduce it." required><%= values.message || '' %></textarea>

        <div class="actions">
          <button class="btn" type="submit">Send ticket</button>
          <a class="btn btn-secondary" href="mailto:<%= supportEmail %>?subject=<%= encodeURIComponent(values.subject || 'Support request from myurlc.com') %>">Email <%= supportEmail %></a>
        </div>
      </form>
    </section>

    <aside class="card billing-side">
      <p class="eyebrow">Support tips</p>
      <h2>Help us fix it faster.</h2>
      <div class="feature-list">
        <div class="feature-item">Tell us what page you were on</div>
        <div class="feature-item">Describe what you expected to happen</div>
        <div class="feature-item">Share the exact error message if you saw one</div>
      </div>

      <div class="card subtle-card">
        <p class="eyebrow">Direct contact</p>
        <h3><%= supportEmail %></h3>
        <p class="section-copy">Use the ticket form for tracked support, or email us directly if that is easier.</p>
        <a class="text-link" href="mailto:<%= supportEmail %>">Email support</a>
      </div>
    </aside>
  </main>
</div>

<%- include("partials/footer") %>
