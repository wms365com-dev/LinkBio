<%- include("partials/header") %>

<% const contactActions = buildPhoneContactActions(order.phone); %>
<% const subscribeHref = order.lead_form_enabled ? '#subscribe' : '/signup'; %>
<% const showSectionLabels = order.link_sections.length > 1; %>
<% const joinHref = order.owner_referral_share_url || '/signup'; %>
<% const visibleName = order.business_name || order.full_name || order.slug; %>
<% const showVisibleName = visibleName && visibleName.toLowerCase() !== order.slug.toLowerCase(); %>

<div class="profile-page profile-page-public profile-theme-<%= order.theme %>" style="--accent:<%= order.accent_color %>;">
  <% if (order.background_image) { %>
    <div class="profile-backdrop" style="background-image:url('<%= order.background_image %>');"></div>
  <% } %>
  <div class="profile-orb orb-a"></div>
  <div class="profile-orb orb-b"></div>

  <div class="profile-shell">
    <div class="profile-topbar">
      <a class="profile-action-button profile-home-link" href="/" aria-label="Back to myurlc.com home" title="Back to myurlc.com">
        <span class="icon-svg"><%- iconSvg("brand") %></span>
      </a>
      <div class="profile-top-actions">
        <a class="profile-action-button" href="<%= subscribeHref %>" aria-label="Subscribe" title="Subscribe">
          <span class="icon-svg"><%- iconSvg("subscribe") %></span>
        </a>
        <button
          class="profile-action-button profile-action-button-ghost"
          type="button"
          data-share-page
          data-share-url="<%= order.public_url %>"
          data-share-title="<%= order.business_name %>"
          data-share-text="Check out <%= order.business_name %> on myurlc.com"
          aria-label="Share this page"
          title="Share this page"
        >
          <span class="icon-svg"><%- iconSvg("share") %></span>
        </button>
      </div>
    </div>

    <div class="profile-card">
      <div class="profile-media-shell">
        <% if (order.profile_media) { %>
          <% if (order.profile_media_type === "video") { %>
            <video class="avatar avatar-video" src="<%= order.profile_media %>" muted loop autoplay playsinline controls></video>
          <% } else { %>
            <img class="avatar" src="<%= order.profile_media %>" alt="<%= order.business_name %>" />
          <% } %>
        <% } else { %>
          <div class="avatar avatar-placeholder"><span><%= (order.business_name || 'L').charAt(0).toUpperCase() %></span></div>
        <% } %>
      </div>

      <% if (showVisibleName) { %>
        <p class="profile-display-name"><%= visibleName %></p>
      <% } %>
      <h1 class="profile-handle">@<%= order.slug %></h1>

      <p class="bio profile-bio-inline"><%= order.bio || "This page is getting a bio update soon." %></p>

      <div class="section-stack">
        <% order.link_sections.forEach(section => { %>
          <section class="link-section-card link-section-card-flat">
            <% if (showSectionLabels) { %>
              <p class="profile-section-label profile-section-label-public"><%= section.label %></p>
            <% } %>
            <div class="profile-links">
              <% section.links.forEach(link => { %>
                <a class="profile-link" href="<%= link.href %>">
                  <span class="profile-link-leading">
                    <span class="profile-link-icon">
                      <span class="icon-svg"><%- iconSvg(link.platform) %></span>
                    </span>
                    <span class="profile-link-copy"><%= link.label %></span>
                  </span>
                  <span class="profile-link-trailing" aria-hidden="true">
                    <span class="icon-svg"><%- iconSvg("more") %></span>
                  </span>
                </a>
              <% }) %>
            </div>
          </section>
        <% }) %>
      </div>

      <% if (order.lead_form_enabled) { %>
        <div class="lead-card" id="subscribe">
          <p class="lead-form-title"><%= order.lead_form_prompt %></p>

          <% if (leadError) { %>
            <div class="error"><%= leadError %></div>
          <% } %>

          <% if (leadSuccess) { %>
            <div class="success"><%= leadSuccess %></div>
          <% } %>

          <form method="POST" action="/p/<%= order.slug %>/lead" class="form-stack">
            <input name="name" placeholder="Your name" required />
            <input name="email" type="email" placeholder="Your email" required />
            <textarea name="message" rows="4" placeholder="How can they help?" required></textarea>
            <button class="btn" type="submit">Send message</button>
          </form>
        </div>
      <% } %>

      <% if (contactActions.length > 0 || order.social_links.length > 0) { %>
        <div class="social-strip social-strip-lower">
          <% contactActions.forEach(action => { %>
            <a class="social-icon social-icon-<%= action.platform %>" href="<%= action.href %>" aria-label="<%= action.label %>" title="<%= action.label %>">
              <span class="icon-svg"><%- iconSvg(action.icon) %></span>
            </a>
          <% }) %>
          <% order.social_links.forEach(link => { %>
            <a class="social-icon social-icon-<%= link.platform %>" href="<%= link.href %>" aria-label="<%= link.label %>" title="<%= link.label %>">
              <span class="icon-svg"><%- iconSvg(link.platform) %></span>
            </a>
          <% }) %>
        </div>
      <% } %>

      <a class="profile-platform-cta" id="join-biolink" href="<%= joinHref %>">Join <%= order.slug %> on myurlc.com</a>
    </div>
  </div>

  <div class="profile-mobile-dock" aria-label="Quick actions">
    <a class="profile-mobile-dock-button" href="<%= subscribeHref %>">
      <span class="icon-svg"><%- iconSvg("subscribe") %></span>
      <span>Subscribe</span>
    </a>
    <button
      class="profile-mobile-dock-button profile-mobile-dock-button-ghost"
      type="button"
      data-share-page
      data-share-url="<%= order.public_url %>"
      data-share-title="<%= order.business_name %>"
      data-share-text="Check out <%= order.business_name %> on myurlc.com"
      aria-label="Share this page"
    >
      <span class="icon-svg"><%- iconSvg("share") %></span>
      <span data-share-label>Share</span>
    </button>
    <a class="profile-mobile-dock-primary" href="<%= joinHref %>">Join @<%= order.slug %></a>
  </div>
</div>

<%- include("partials/footer") %>
