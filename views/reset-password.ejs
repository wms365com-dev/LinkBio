<%- include("partials/header") %>

<div class="site-shell">
  <header class="simple-nav container">
    <a class="brand-mark" href="/">myurlc.com</a>
    <a class="text-link" href="/login">Back to login</a>
  </header>

  <main class="container auth-grid auth-grid-compact">
    <section class="card auth-form-card">
      <p class="eyebrow">Secure reset</p>
      <h1>Choose a new password</h1>

      <% if (emailHint && tokenValid) { %>
        <p class="field-hint">Resetting the password for <strong><%= emailHint %></strong>.</p>
      <% } else { %>
        <p class="field-hint">Use the secure link from your email to choose a new password.</p>
      <% } %>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <% if (info) { %>
        <div class="success"><%= info %></div>
      <% } %>

      <% if (tokenValid) { %>
        <form method="POST" action="/reset-password" class="form-stack">
          <input name="token" type="hidden" value="<%= token || values.token || '' %>" />

          <label>New password</label>
          <input name="password" type="password" minlength="8" required />

          <label>Confirm password</label>
          <input name="confirm_password" type="password" minlength="8" required />
          <p class="field-hint">Use at least 8 characters.</p>

          <button class="btn" type="submit">Save new password</button>
        </form>
      <% else { %>
        <p class="auth-switch">
          Need a new link?
          <a class="text-link" href="/forgot-password">Request another reset email</a>
        </p>
      <% } %>
    </section>
  </main>
</div>

<%- include("partials/footer") %>
