<%- include("partials/header") %>

<div class="site-shell">
  <header class="marketing-nav container">
    <a class="brand-mark" href="/">LinkBio Studio</a>
    <div class="nav-actions">
      <% if (currentCustomer) { %>
        <a class="btn btn-ghost" href="<%= currentCustomer.can_access_studio ? '/studio' : '/billing' %>"><%= currentCustomer.can_access_studio ? 'Open Studio' : 'Billing' %></a>
        <form method="POST" action="/logout">
          <button class="btn btn-secondary" type="submit">Log Out</button>
        </form>
      <% } else { %>
        <a class="btn btn-ghost" href="/login">Log In</a>
        <a class="btn" href="/signup">Sign Up</a>
      <% } %>
      <a class="btn btn-ghost" href="/admin/login">Admin</a>
    </div>
  </header>

  <main class="container">
    <section class="card hero-card">
      <div class="hero-copy">
        <p class="eyebrow">Self-serve or done-for-you</p>
        <h1>Let people sign up and build branded bio pages like Linktree.</h1>
        <p class="lead">
          Customers can create an account, start customizing their page right away, and publish it
          themselves. Every self-serve account starts with a <%= trialDays %>-day free trial, then moves to <%= planPriceDisplay %>.
        </p>
        <div class="actions">
          <a class="btn" href="<%= currentCustomer ? (currentCustomer.can_access_studio ? '/studio' : '/billing') : '/signup' %>"><%= currentCustomer ? (currentCustomer.can_access_studio ? 'Open your studio' : 'Upgrade your account') : 'Create an account' %></a>
          <a class="btn btn-secondary" href="/buy">Offer done-for-you setup</a>
        </div>
        <div class="hero-badges">
          <span><%= trialDays %>-day free trial</span>
          <span>Self-serve page builder</span>
          <span>Railway-ready hosting</span>
          <span>Customer signup + login</span>
          <span>Admin-managed back office</span>
        </div>

        <% if (recentSignups && recentSignups.length > 0) { %>
          <div class="announcement-card">
            <p class="announcement-label">New signups</p>
            <div class="announcement-feed">
              <% recentSignups.slice(0, 3).forEach(item => { %>
                <div class="announcement-item">
                  <strong><%= item.business_name %></strong>
                  <span><%= item.relative_created_at %></span>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>
      </div>

      <div class="hero-preview">
        <div class="phone-frame">
          <div class="phone-card">
            <div class="phone-avatar"></div>
            <p class="phone-title">Grey Wolf Logistics</p>
            <p class="phone-copy">Overflow warehouse, same-day pallet help, custom quotes.</p>
            <div class="phone-link">Book a quote</div>
            <div class="phone-link phone-link-alt">Call now</div>
            <div class="phone-link phone-link-soft">Instagram</div>
          </div>
        </div>
      </div>
    </section>

    <section class="grid two social-proof-grid">
      <article class="card">
        <div class="section-header">
          <div>
            <p class="eyebrow">Just joined</p>
            <h2>Show visitors fresh activity</h2>
          </div>
        </div>
        <div class="signup-proof-list">
          <% if (!recentSignups || recentSignups.length === 0) { %>
            <div class="empty-state">
              <h3>No signups yet</h3>
              <p>Once accounts start coming in, this feed becomes social proof for new visitors.</p>
            </div>
          <% } %>

          <% (recentSignups || []).forEach(item => { %>
            <article class="signup-proof-item">
              <div>
                <strong><%= item.business_name %></strong>
                <p><%= item.message %></p>
              </div>
              <span><%= item.relative_created_at %></span>
            </article>
          <% }) %>
        </div>
      </article>

      <article class="card">
        <div class="section-header">
          <div>
            <p class="eyebrow">Referral loop</p>
            <h2>Reward customers for bringing the next one in</h2>
          </div>
        </div>
        <div class="feature-list">
          <div class="feature-item">Every account gets a shareable referral link</div>
          <div class="feature-item">Each successful referral earns 1 free month</div>
          <div class="feature-item">Rewards stack up to 12 months of free service</div>
        </div>
        <a class="btn" href="<%= currentCustomer ? '/billing' : '/signup' %>"><%= currentCustomer ? 'Open referral tools' : 'Create an account' %></a>
      </article>
    </section>

    <section class="grid three">
      <article class="card">
        <p class="card-number">01</p>
        <h2>Customer signs up</h2>
        <p>They create an account, claim their page, and start customizing immediately.</p>
      </article>
      <article class="card">
        <p class="card-number">02</p>
        <h2>Customer customizes</h2>
        <p>They pick a theme, upload a logo, add buttons, and preview the page live.</p>
      </article>
      <article class="card">
        <p class="card-number">03</p>
        <h2>Publish or upsell</h2>
        <p>Let them publish on their own, or keep your manual setup flow for premium service tiers.</p>
      </article>
    </section>

    <section class="card">
      <div class="section-header">
        <div>
          <p class="eyebrow">Theme ideas</p>
          <h2>Offer layouts that feel different</h2>
        </div>
        <a class="text-link" href="/signup">Build one now</a>
      </div>

      <div class="template-grid">
        <article class="template-card theme-midnight-demo">
          <span>Midnight Glass</span>
          <strong>Great for DJs, creators, nightlife, and event brands.</strong>
        </article>
        <article class="template-card theme-linen-demo">
          <span>Linen Studio</span>
          <strong>Clean and premium for beauty, wellness, and personal brands.</strong>
        </article>
        <article class="template-card theme-sunset-demo">
          <span>Sunset Pop</span>
          <strong>Bright and direct for small business promos and local service offers.</strong>
        </article>
      </div>
    </section>

    <section class="card">
      <div class="section-header">
        <div>
          <p class="eyebrow">Published examples</p>
          <h2>Pages your customers can share</h2>
        </div>
      </div>

      <div class="grid three">
        <% if (published.length === 0) { %>
          <div class="empty-state">
            <h3>No pages published yet</h3>
            <p>Create an account, publish a sample page, and this section becomes instant social proof.</p>
          </div>
        <% } %>

        <% published.forEach(item => { %>
          <a class="example-card" href="/p/<%= item.slug %>">
            <% if (item.profile_image) { %>
              <img class="example-thumb" src="<%= item.profile_image %>" alt="<%= item.business_name %>" />
            <% } %>
            <strong><%= item.business_name %></strong>
            <span><%= item.bio || "Branded link-in-bio page" %></span>
            <small><%= baseUrl %>/p/<%= item.slug %></small>
          </a>
        <% }) %>
      </div>
    </section>
  </main>
</div>

<%- include("partials/footer") %>
